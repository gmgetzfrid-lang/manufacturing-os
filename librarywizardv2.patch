+  const moveField = (i: number, dir: "up" | "down") => {
+    setColumns((f) => {
+      const next = [...f];
+      const swap = dir === "up" ? i - 1 : i + 1;
+      if (swap < 0 || swap >= next.length) return f;
+      [next[i], next[swap]] = [next[swap], next[i]];
+      return next;
+    });
+  };
 
