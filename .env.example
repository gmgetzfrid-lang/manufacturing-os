# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# ─── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
# ─── MPP converter (optional, for full-fidelity .mpp import) ───
# Point this at the MPXJ converter service (see services/mpp-converter/).
# When set, dropped .mpp files are parsed completely — dependencies,
# resources, custom columns, exact dates — with zero export step for the user.
# Leave unset to fall back to the best-effort pure-JS parser.
MPP_CONVERTER_URL=
MPP_CONVERTER_TOKEN=
